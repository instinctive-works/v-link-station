{
  "name": "@v-link/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron main process for V-Link Station",
  "author": "V-Link",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:dir": "electron-builder --dir"
  },
  "build": {
    "appId": "com.vlink.station",
    "productName": "V-Link Station",
    "asar": false,
    "npmRebuild": false,
    "directories": {
      "output": "../../dist"
    },
    "files": [
      "electron/**",
      "../../apps/server/**",
      "../../packages/renderer/**",
      "../../packages/shared/**",
      "../../packages/protocols/**",
      "package.json"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  }
}
